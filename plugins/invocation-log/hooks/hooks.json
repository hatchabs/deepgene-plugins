{
  "description": "Logs every tool invocation to ~/.claude/dgai-invocations.jsonl for KPI tracking.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-skill-log.py\""
          }
        ]
      }
    ]
  }
}
